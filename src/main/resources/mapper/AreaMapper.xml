<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.express.yto.dao.AreaMapper">
  <resultMap id="BaseResultMap" type="com.express.yto.model.Area">
    <!--@mbg.generated-->
    <!--@Table t_area-->
    <id column="id" jdbcType="BIGINT" property="id"/>
    <result column="company_id" jdbcType="VARCHAR" property="companyId"/>
    <result column="area_num" jdbcType="INTEGER" property="areaNum"/>
    <result column="area_city" jdbcType="VARCHAR" property="areaCity"/>
  </resultMap>
  <sql id="Base_Column_List">
    <!--@mbg.generated-->
    id, company_id, area_num, area_city
  </sql>
  <select id="getList" resultType="com.express.yto.dto.AreaListDTO">
    select
        t2.company_name AS companyName,
        t1.company_id AS companyId,
        t1.area_num AS areaNum,
        t1.area_city AS areaCity
    from t_area t1, t_company t2
    where t1.company_id = t2.company_id

  </select>


</mapper>